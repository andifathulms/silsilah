# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres — leave POSTGRES_DB unset to use sqlite in dev
POSTGRES_DB=silsilah
POSTGRES_USER=silsilah
POSTGRES_PASSWORD=silsilah
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# S3 / MinIO media storage — set USE_S3=true to enable
USE_S3=false
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=silsilah-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_USE_SSL=false

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
